{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Asan",
            "type": "shell",
            "command": "cmake --preset asan",
            "group": "build"
        },
        {
            "label": "Build Asan",
            "type": "shell",
            "command": "cmake --build out/build/asan",
            "group": "build"
        },
        {
            "label": "Configure and Build Asan",
            "type": "shell",
            "command": "echo Done!",
            "dependsOn": [
                "Configure Asan",
                "Build Asan"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
